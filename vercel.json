{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "includeFiles": "{main.py,business_config.json}"
    }
  },
  "rewrites": [
    {
      "source": "/(webhook|reply|voice|health|process-followups)(?:.*)",
      "destination": "/api/index"
    },
    {
      "source": "/config/reload(?:.*)",
      "destination": "/api/index"
    }
  ]
}
