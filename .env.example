# Supabase (required outside TEST_MODE)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Twilio (required outside TEST_MODE)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your-auth-token

# Webhook security — use a strong random string (min 32 chars)
WEBHOOK_SECRET=change-me-to-a-random-32-char-string

# Full public URL of this app (required for Twilio webhook signature validation)
APP_BASE_URL=https://your-app.vercel.app

# Comma-separated list of allowed CORS origins (e.g. https://yourdomain.com)
CORS_ORIGINS=https://yourdomain.com

# Set to "true" to skip real SMS sends, DB writes, and external client init during local testing
TEST_MODE=false

# --- Frontend (Next.js) environment variables ---
# Public Supabase credentials for the browser (use anon key, NOT service key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend URL used by Next.js API routes (server-side only, never exposed to browser)
# Set this to your Vercel deployment URL on Vercel, or http://localhost:8000 locally
API_URL=https://your-app.vercel.app
